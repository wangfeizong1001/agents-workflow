{
  "name": "@agents-workflow/yunshou",
  "version": "0.1.0",
  "description": "云枢 —— AI 编程工作流框架,统一规格、计划、执行、验证",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/opencode": {
      "types": "./dist/adapters/opencode/index.d.ts",
      "import": "./dist/adapters/opencode/index.js"
    }
  },
  "bin": {
    "yunshou": "./dist/interfaces/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "ci": "bun run lint && bun run typecheck && bun run test"
  },
  "keywords": [
    "ai",
    "workflow",
    "spec-driven",
    "mcp",
    "opencode",
    "yunshou"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
